# RAVID environment configuration — copy to .env and fill in real values.
# .env is git-ignored; THIS file (.env.example) is committed with safe placeholders only.
# Never commit real secrets. Canonical locked values live in
# .agents/references/assessment-decisions.md.

# ── Django ──────────────────────────────────────────────────────────────────
# Generate a unique key per deployment; the placeholder is NOT safe for prod.
DJANGO_SECRET_KEY=django-insecure-change-me-before-sharing
# Settings module to load. Use config.settings.local for dev, config.settings.prod for prod.
DJANGO_SETTINGS_MODULE=config.settings.local
# 1/true enables debug; keep 0 in any shared/prod environment.
DEBUG=1
# Comma-separated hosts Django will serve.
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_DB=ravid
POSTGRES_USER=ravid
POSTGRES_PASSWORD=ravid
POSTGRES_HOST=db
POSTGRES_PORT=5432
# Optional single-URL form; if set, takes precedence over the POSTGRES_* parts above.
DATABASE_URL=postgres://ravid:ravid@db:5432/ravid

# ── Redis / Celery ──────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ── OpenRouter (LLM gateway, OpenAI-compatible chat/completions) ─────────────
# Required at runtime. Get a key at https://openrouter.ai/. Keep it secret.
OPENROUTER_API_KEY=sk-or-your-openrouter-key-here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Free slugs rotate — verify the model is still available at implementation time.
OPENROUTER_MODEL=mistralai/mistral-7b-instruct:free

# ── Embeddings (local HuggingFace, no key, offline after first download) ──────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Chroma (vector store) ───────────────────────────────────────────────────
CHROMA_HOST=chroma
CHROMA_PORT=8000
# Where Chroma persists data; mounted as a Docker volume in the compose stack.
CHROMA_PERSIST_DIR=/data/chroma

# ── RAG / upload tuning (locked decision values) ────────────────────────────
# Max upload size in MB; files larger than this are rejected with HTTP 400.
MAX_UPLOAD_MB=10
# RecursiveCharacterTextSplitter parameters.
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
# Number of chunks retrieved per query (cosine similarity).
RETRIEVAL_TOP_K=4
